{
  "name": "flow-visualiser",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "VITE_BASE_PATH=${VITE_BASE_PATH:-/hypersonics-visualiser/} npm run build",
    "preview": "vite preview",
    "preview:pages": "npm run build:pages && vite preview --base /hypersonics-visualiser/",
    "deploy": "npm run build:pages && touch dist/.nojekyll && gh-pages -d dist --dotfiles",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@react-three/drei": "^10.0.5",
    "@react-three/fiber": "^9.1.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.175.0",
    "three-stdlib": "^2.35.16",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/three": "^0.175.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@webgpu/types": "^0.1.71",
    "gh-pages": "^6.3.0",
    "typescript": "~5.7.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.8"
  }
}
